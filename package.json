{
  "name": "blogsite",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "npm run search:index && npm run feed && npm run api && next dev --turbopack",
    "build": "npm run search:index && npm run feed && npm run api && next build",
    "preview": "npx serve out -l 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "new-post": "node scripts/new-post.mjs",
    "search:index": "node scripts/build-search-index.mjs",
    "feed": "node scripts/generate-feed.mjs",
    "api": "node scripts/generate-papers-api.mjs"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@phosphor-icons/react": "^2.1.10",
    "@shikijs/rehype": "^4.3.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "minisearch": "^7.2.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-cjk-friendly": "^2.3.1",
    "remark-cjk-friendly-gfm-strikethrough": "^2.3.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.3",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.9.3"
  }
}
